      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[OrderedDict([('videos', './resources/videos/Clip 1 - PsychoPY.mp4')]), OrderedDict([('videos', './resources/videos/Clip 2 - PsychoPY.mp4')]), OrderedDict([('videos', './resources/videos/Clip 3 - PsychoPY.mp4')]), OrderedDict([('videos', './resources/videos/Clip 4 - PsychoPY.mp4')]), OrderedDict([('videos', './resources/videos/Clip 5 - PsychoPY.mp4')]), OrderedDict([('videos', './resources/videos/Clip 6 - PsychoPY.mp4')]), OrderedDict([('videos', './resources/videos/Clip 7 - PsychoPY.mp4')]), OrderedDict([('videos', './resources/videos/Clip 8 - PsychoPY.mp4')]), OrderedDict([('videos', './resources/videos/Clip 9 - PsychoPY.mp4')]), OrderedDict([('videos', './resources/videos/Clip 10 - PsychoPY.mp4')])]" valType="str"/>
