        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="Nesta tarefa, irá observar pequenos vídeos de situações de jogo.&amp;#10;&amp;#10;Após cada vídeo, surgirá uma imagem congelada do lance e terá de tomar uma decisão com base na informação apresentada no ecrã.&amp;#10;Responda o mais rapidamente e corretamente possível, utilizando as teclas indicadas. Prima a tecla correspondente à opção apresentada no ecrã (A, B, C, D).&amp;#10;&amp;#10;Entre ensaios, será apresentada uma cruz de fixação ao centro do ecrã; durante esse período, deverá manter o olhar fixo no centro e evitar movimentos desnecessários.&amp;#10;&amp;#10;Antes do início, haverá um breve período de preparação.&amp;#10;&amp;#10;Quando estiver pronto, prima a barra de espaço para começar.&amp;#10;&amp;#10;" valType="str" updates="constant" name="text"/>
